      <aliases enabled='yes' />
      <column caption='Flight Balance' datatype='integer' name='[Calculation_0653702849236992]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [measure] = &quot;Arrivals&quot; THEN [flights] END)&#13;&#10;-&#13;&#10;SUM(IF [measure] = &quot;Departures&quot; THEN [flights] END)' />
      </column>
      <column caption='Passenger Growth' datatype='integer' name='[Calculation_0653702992551937]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([passengers]) - LOOKUP(SUM([passengers]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Passengers per Flight' datatype='real' name='[Calculation_0653703028854791]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([passengers]) / SUM([flights])' />
      </column>
      <column caption='Passenger Market Share %' datatype='real' name='[Calculation_0653703029977096]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([passengers]) / TOTAL(SUM([passengers]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Passenger Growth Index' datatype='real' name='[Calculation_0653703031635978]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(passengers) / &#13;&#10;WINDOW_MIN(SUM(passengers)) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column aggregation='None' caption='Flights (classe)' datatype='integer' name='[Flights (classe)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='4' formula='[flights]' peg='0' size='100000' />
      </column>
